# Normaliza todas as extremidades de linha para LF no repositório.
# Arquivos de texto verificados com text=auto receberão a conversão correta
# no checkout (LF no Linux/macOS, CRLF no Windows) se eol não for forçado.
* text=auto eol=lf

# Batch scripts do Windows exigem CRLF
*.bat text eol=crlf

# Binários — sem conversão de linha
*.jar   binary
*.class binary
